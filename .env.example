# SlimeVR Docker - Configuration Examples
# Copy to .env and customize if needed

# WEBGUI_PORT=8080
# SLIMEVR_VERSION=latest

# Serial group GID for USB tracker access (default: not set = uses dialout)
# Only needed if your distro uses a non-standard group (e.g. Arch uucp = 984)
# Find yours: ls -ln /dev/ttyACM0 | awk '{print $4}'
# SERIAL_GID=